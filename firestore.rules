rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Collection validation rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && incoming().userId == userId;
      allow update: if isOwner(userId) && incoming().userId == userId;
      allow delete: if false;

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /social_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().hostId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;
    }
  }
}
