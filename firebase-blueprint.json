{
  "entities": {
    "User": {
      "title": "User Profile and Pet Status",
      "description": "Stores user stats, current coins, username, and their pet companion state.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user ID" },
        "username": { "type": "string", "description": "Display name selected by user" },
        "level": { "type": "integer", "description": "Current pet level" },
        "experience": { "type": "integer", "description": "Current pet XP" },
        "maxExperience": { "type": "integer", "description": "XP to reach next level" },
        "energy": { "type": "number", "description": "Energy of the pet (0 to 100)" },
        "skin": { "type": "string", "description": "Currently equipped skin" },
        "status": { "type": "string", "description": "Current activity state of pet" },
        "coins": { "type": "integer", "description": "Total coins in economy" },
        "lastActiveTime": { "type": "string", "format": "date-time", "description": "Last timestamp the user opened or interacted with the app used to decrement energy" },
        "isDead": { "type": "boolean", "description": "Whether the pet is dead on last load" },
        "potionCount": { "type": "integer", "description": "Number of revive potions stored" },
        "lastPotionPurchaseWeek": { "type": "string", "description": "Year-week indicator of last revive purchase" },
        "potionPurchasesThisWeek": { "type": "integer", "description": "Count of times revive potion purchased this week" },
        "foodInventory": { "type": "integer", "description": "Count of available food items" }
      },
      "required": ["userId", "username"]
    },
    "Task": {
      "title": "Task",
      "description": "A productivity task representing a user goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["normal", "importante", "urgente"] },
        "estimatedPomodoros": { "type": "integer" },
        "completedPomodoros": { "type": "integer" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "completed"]
    },
    "SocialSession": {
      "title": "SocialSession",
      "description": "A group focus session where multiple friends do Pomodoro together in real-time.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hostName": { "type": "string" },
        "hostId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "currentTimer": { "type": "integer", "description": "Seconds remaining in pomodoro" },
        "timerMode": { "type": "string", "enum": ["focus", "short", "long"] },
        "isActive": { "type": "boolean" },
        "participants": { "type": "array", "description": "Array of participant shapes" }
      },
      "required": ["id", "hostId", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profile document containing stats and pet parameters"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "Task" },
      "description": "Sub-collection of tasks owned by this user"
    },
    "/social_sessions/{sessionId}": {
      "schema": { "$ref": "SocialSession" },
      "description": "Active session rooms for real-time multiplayer co-working"
    }
  }
}
